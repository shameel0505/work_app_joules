generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  TASKER
  ADMIN
}

enum TaskStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_TASKERS_FOUND
  DISPUTED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

enum NotificationType {
  NEW_BID
  BID_ACCEPTED
  BID_REJECTED
  TASK_STARTED
  TASK_COMPLETED
  NEW_MESSAGE
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  PROMO_APPLIED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  phone             String   @unique
  role              UserRole @default(CUSTOMER)
  firstName         String
  lastName          String
  password          String?
  avatarUrl         String?
  preferredLang     String   @default("en")
  walletBalanceFils Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tasker             Tasker?
  tasksAsCustomer    Task[]              @relation("CustomerTasks")
  messagesSent       Message[]           @relation("SentMessages")
  reviewsGiven       Review[]            @relation("ReviewsGiven")
  reviewsReceived    Review[]            @relation("ReviewsReceived")
  payments           Payment[]           @relation("CustomerPayments")
  notifications      Notification[]
  walletTransactions WalletTransaction[]
  savedAddresses     SavedAddress[]
  refreshTokens      RefreshToken[]

  @@index([phone])
}

model Tasker {
  id                  String   @id @default(uuid())
  userId              String   @unique
  bio                 String?
  rating              Float    @default(0)
  completedTasksCount Int      @default(0)
  location            String?
  isVerified          Boolean  @default(false)
  serviceRadiusKm     Float?
  hourlyRateFils      Int?
  skills              String[]
  isOnline            Boolean  @default(false)
  currentLat          Float?
  currentLng          Float?
  emiratesIdFrontUrl  String?
  emiratesIdBackUrl   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasksAsTasker Task[] @relation("TaskerTasks")
  bids          Bid[]

  @@index([location])
}

model Category {
  id            String   @id @default(uuid())
  nameEn        String   @unique
  nameAr        String   @unique
  icon          String
  basePriceFils Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tasks Task[]
}

model Task {
  id                  String     @id @default(uuid())
  customerId          String
  taskerId            String?
  categoryId          String
  title               String
  description         String
  status              TaskStatus @default(PENDING)
  locationLat         Float
  locationLng         Float
  locationAddress     String
  budgetFils          Int
  priceFinal          Int?
  photos              String[]
  specialInstructions String?
  isRecurring         Boolean    @default(false)
  scheduledAt         DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  completionNotes     String?
  completionPhotos    String[]
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  customer User      @relation("CustomerTasks", fields: [customerId], references: [id])
  tasker   Tasker?   @relation("TaskerTasks", fields: [taskerId], references: [id])
  category Category  @relation(fields: [categoryId], references: [id])
  bids     Bid[]
  messages Message[]
  reviews  Review[]
  payments Payment[]

  @@index([status])
  @@index([customerId])
  @@index([taskerId])
}

model Bid {
  id         String    @id @default(uuid())
  taskId     String
  taskerId   String
  amountFils Int
  message    String?
  etaMinutes Int
  status     BidStatus @default(PENDING)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  task   Task   @relation(fields: [taskId], references: [id])
  tasker Tasker @relation(fields: [taskerId], references: [id])

  @@unique([taskId, taskerId])
}

model Message {
  id        String      @id @default(uuid())
  taskId    String
  senderId  String
  content   String
  type      MessageType @default(TEXT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  readAt    DateTime?

  task   Task @relation(fields: [taskId], references: [id])
  sender User @relation("SentMessages", fields: [senderId], references: [id])
}

model Review {
  id         String   @id @default(uuid())
  taskId     String
  reviewerId String
  revieweeId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  task     Task @relation(fields: [taskId], references: [id])
  reviewer User @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee User @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@unique([taskId, reviewerId])
}

model Payment {
  id                String        @id @default(uuid())
  taskId            String
  customerId        String
  amountFils        Int
  status            PaymentStatus @default(PENDING)
  providerPaymentId String?       @unique
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  task     Task @relation(fields: [taskId], references: [id])
  customer User @relation("CustomerPayments", fields: [customerId], references: [id])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WalletTransaction {
  id          String   @id @default(uuid())
  userId      String
  amountFils  Int
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PromoCode {
  id            String       @id @default(uuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Int
  maxUses       Int?
  usesCount     Int          @default(0)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model SavedAddress {
  id               String   @id @default(uuid())
  userId           String
  title            String
  formattedAddress String
  lat              Float
  lng              Float
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
